    "import os, torch\n",
    "os.environ[\"PYTORCH_ALLOC_CONF\"] = \"expandable_segments:True\"\n",
    "\n",
    "from unsloth import FastLanguageModel\n",
    "\n",
    "MODEL_ID   = \"Qwen/Qwen2.5-7B-Instruct\"  # swap to 7B if VRAM allows\n",
    "MAX_SEQ_LEN = 2048   # covers prompt + short action response; reduce to 1024 if still OOM\n",
    "\n",
    "model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "    model_name       = MODEL_ID,\n",
    "    max_seq_length   = MAX_SEQ_LEN,\n",
    "    dtype            = None,          # auto: bf16 on Ampere+, fp16 on older\n",
    "    load_in_4bit     = True,          # QLoRA — cuts base weights to ~1 GB for 1.5B\n",
    "    token            = HF_TOKEN,\n",
    ")\n",
    "\n",
    "# Wrap with LoRA — Unsloth patches the adapters for fused kernels automatically\n",
    "model = FastLanguageModel.get_peft_model(\n",
    "    model,\n",
    "    r                   = 16,\n",
    "    lora_alpha          = 32,\n",
    "    lora_dropout        = 0,          # 0 is optimal for Unsloth\n",
    "    target_modules      = [\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n",
    "                           \"gate_proj\", \"up_proj\", \"down_proj\"],\n",
    "    bias                = \"none\",\n",
    "    use_gradient_checkpointing = \"unsloth\",  # saves ~30% VRAM vs standard checkpointing\n",
    "    random_state        = 42,\n",
    "    use_rslora          = False,\n",
    "    loftq_config        = None,\n",
    ")\n",
    "model.print_trainable_parameters()\n",
    "\n",
    "tokenizer.padding_side = \"left\"\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "used  = torch.cuda.memory_allocated() / 1e9\n",
    "total = torch.cuda.get_device_properties(0).total_memory / 1e9\n",
    "print(f\"Model ready | VRAM: {used:.1f}/{total:.1f} GB\")\n",
    "model.generation_config.max_length = None"
   ]
