    "## 3. Test Environment Connection\n",
    "\n",
    "Verify your HF Space is live before starting training."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests, json\n",
    "\n",
    "def test_env(base_url):\n",
    "    print(f\"Testing: {base_url}\")\n",
    "\n",
    "    # 1) Health probe (cicd_api app exposes /health)\n",
    "    try:\n",
    "        r = requests.get(f\"{base_url}/health\", timeout=30)\n",
    "        r.raise_for_status()\n",
    "        print(f\"  /health  -> {r.json()}\")\n",
    "    except Exception as e:\n",
    "        print(f\"  /health  FAILED: {e}\")\n",
    "        return None\n",
    "\n",
    "    # 2) Create a workspace - the actual training entry point.\n",
    "    try:\n",
    "        r = requests.post(f\"{base_url}/api/workspace/create\",\n",
    "                          json={\"fault_type\": None}, timeout=120)\n",
    "        r.raise_for_status()\n",
    "        body = r.json()\n",
    "        wid  = body.get(\"workspace_id\")\n",
    "        fault = body.get(\"fault_injected\")\n",
    "        logs  = body.get(\"initial_failure_logs\") or \"\"\n",
    "        print(f\"  workspace_id     : {wid}\")\n",
    "        print(f\"  fault_injected   : {fault}\")\n",
    "        print(f\"  initial_failure  : {(logs[:200] + '...') if len(logs) > 200 else logs!r}\")\n",
    "        return body\n",
    "    except Exception as e:\n",
    "        print(f\"  /api/workspace/create FAILED: {e}\")\n",
    "        return None\n",
    "\n",
    "ws_probe = test_env(ENV_BASE_URL)\n",
    "print(\"Environment ready!\" if ws_probe else \"Fix connection before proceeding\")\n"
   ]
  },
