   "source": [
    "## 7. Episode Rollout Function\n",
    "\n",
    "Runs one full episode and captures the full trajectory (prompts, responses, rewards) for GRPO training."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from dataclasses import dataclass, field as dc_field\n",
    "import torch\n",
    "\n",
    "@dataclass\n",
    "class Trajectory:\n",
    "    prompts:      list = dc_field(default_factory=list)\n",
    "    responses:    list = dc_field(default_factory=list)\n",
    "    rewards:      list = dc_field(default_factory=list)\n",
    "    total_reward: float = 0.0\n",
    "    final_score:  float = 0.0\n",
    "    resolved:     bool  = False\n",
    "    steps:        int   = 0\n",
    "    task_id:      str   = \"\"\n",
    "    difficulty:   str   = \"\"\n",
    "\n",
    "\n",
    "def _last_read_path(action_history):\n",
    "    for op, tgt, _ in reversed(action_history):\n",
    "        if op == \"read_file\" and tgt:\n",
    "            return tgt\n",
    "    return \"\"\n",
    "\n",
    "\n",
    "def run_episode(env, model, tokenizer, max_steps=16, max_tokens=512, verbose=True):\n",
    "    \"\"\"One episode against the WS env. Mirrors guardrail logic of agent/runner.py::run_task_ws.\"\"\"\n",
    "    traj = Trajectory()\n",
    "    action_history = []\n",
    "    attempted_hypotheses: set = set()\n",
    "    forced_messages: list = []\n",
    "    read_files: set = set()\n",
    "    read_file_contents: dict = {}   # path -> content cache for context injection\n",
    "    hypothesis_set: bool = False    # True once a hypothesis has been accepted\n",
    "    fix_applied_since_rerun = False\n",
    "    pipeline_passed = False\n",
    "\n",
    "    obs = env.reset()\n",
    "    fault = obs.get(\"fault_injected\") or \"\"\n",
    "    traj.task_id = fault or obs.get(\"task_id\", \"?\")\n",
    "    traj.difficulty = obs.get(\"difficulty\", \"\")\n",
    "\n",
    "    system_prompt = _get_system_prompt(fault)\n",
    "\n",
    "    if verbose:\n",
    "        print(f\"\\n{'='*70}\\n[EPISODE START] fault={fault} workspace={env.workspace_id[:8]}\\n{'='*70}\")\n",
    "        print(\"[INITIAL OBS]\")\n",
    "        print(env.obs_to_text(obs, 0)[:1200])\n",
    "        print()\n",
    "\n",
    "    result = None\n",
    "    for step_i in range(max_steps):\n",
    "        obs_text = env.obs_to_text(obs, step_i + 1)\n",
    "\n",
    "        # After hypothesis accepted, inject cached file content so the model\n",
    "        # can write without re-reading (prevents read -> hyp -> read -> hyp loop)\n",
    "        extra_context = \"\"\n",
    "        if hypothesis_set and not fix_applied_since_rerun:\n",
    "            last_read = _last_read_path(action_history)\n",
    "            if last_read and last_read in read_file_contents:\n",
    "                content = read_file_contents[last_read]\n",
    "                extra_context = (\n",
    "                    f\"\\n\\n=== CACHED FILE: {last_read} ===\\n\"\n",
    "                    + \"\\n\".join(content.splitlines()[:120])\n",
    "                    + \"\\n=== END CACHED FILE ===\"\n",
    "                    + f\"\\n\\nYou have already read {last_read} and set a hypothesis.\"\n",
    "                    + \" Your ONLY valid next action is:\"\n",
    "                    + f\"\\n  ACTION: write_file|{last_read}|<complete corrected content>\"\n",
    "                )\n",
    "\n",
    "        user_content = obs_text + extra_context\n",
    "        if forced_messages:\n",
    "            user_content += \"\\n\\n\" + \"\\n\".join(f\"Guardrail: {m}\" for m in forced_messages)\n",
    "            forced_messages.clear()\n",
    "\n",
    "        messages = [\n",
    "            {\"role\": \"system\", \"content\": system_prompt},\n",
    "            {\"role\": \"user\",   \"content\": user_content + \"\\n\\nChoose your next action.\"},\n",
    "        ]\n",
    "        chat = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "        inputs = tokenizer(chat, return_tensors=\"pt\", truncation=True, max_length=MAX_SEQ_LEN).to(model.device)\n",
    "\n",
    "        FastLanguageModel.for_inference(model)\n",
    "        with torch.no_grad():\n",
    "            out = model.generate(\n",
    "                **inputs, max_new_tokens=max_tokens,\n",
    "                do_sample=True, temperature=0.7, top_p=0.9,\n",
    "                pad_token_id=tokenizer.eos_token_id,\n",
    "                eos_token_id=tokenizer.eos_token_id,\n",
    "            )\n",
    "        FastLanguageModel.for_training(model)\n",
    "        gen_ids = out[0, inputs[\"input_ids\"].shape[1]:]\n",
    "        response = tokenizer.decode(gen_ids, skip_special_tokens=True)\n",
    "\n",
    "        action = parse_action(response)\n",
    "        op, tgt, val = action.operation, action.target, action.value\n",
    "\n",
    "        # Guardrail: write_file with empty path\n",
    "        if op == \"write_file\" and not tgt:\n",
    "            last_read = _last_read_path(action_history)\n",
    "            op, tgt, val = (\"read_file\", last_read, \"\") if last_read else (\"trigger_pipeline\", \"\", \"\")\n",
    "            forced_messages.append(\n",
    "                \"write_file requires path AND complete file content. \"\n",
    "                f\"Re-issue write_file(path='{last_read or '<file>'}', content='<entire corrected file>').\")\n",
    "\n",
    "        # Guardrail: read-before-write\n",
    "        if op == \"write_file\" and tgt and tgt not in read_files:\n",
    "            forced_messages.append(f\"You must read_file('{tgt}') before writing it.\")\n",
    "            op, tgt, val = \"read_file\", tgt, \"\"\n",
    "\n",
    "        # Guardrail: block re-reading same file after hypothesis already set\n",
    "        if op == \"read_file\" and tgt and tgt in read_files and hypothesis_set and not fix_applied_since_rerun:\n",
    "            last_read = _last_read_path(action_history)\n",
    "            forced_messages.append(\n",
    "                f\"You already read '{tgt}' and set a hypothesis. \"\n",
    "                f\"Do NOT re-read — write_file('{last_read or tgt}', <complete corrected content>) now.\")\n",
    "            # Force write_file with cached content if we have it\n",
    "            if last_read and last_read in read_file_contents:\n",
    "                op, tgt, val = \"write_file\", last_read, read_file_contents[last_read]\n",
    "            else:\n",
    "                op, tgt, val = \"write_file\", tgt, \"\"\n",
    "\n",
    "        # Guardrail: dedup hypothesis\n",
    "        if op == \"set_hypothesis\":\n",
    "            norm = _normalize_hypothesis(val)\n",
    "            if norm and norm in attempted_hypotheses:\n",
    "                forced_messages.append(\"That hypothesis already scored negatively. Re-read the incident alert.\")\n",
    "                op, tgt, val = \"read_file\", _last_read_path(action_history) or \"services/api/routes.py\", \"\"\n",
    "\n",
    "        # Guardrail: dedup exact action (allow re-trigger after a new fix)\n",
    "        action_tuple = (op, tgt, val)\n",
    "        already = action_tuple in action_history\n",
    "        rerun_blocked = already and not (op == \"trigger_pipeline\" and fix_applied_since_rerun)\n",
    "        if rerun_blocked:\n",
    "            forced_messages.append(\"Repeat action blocked. Try a different op or target.\")\n",
    "            if op == \"write_file\":\n",
    "                op, tgt, val = \"trigger_pipeline\", \"\", \"\"\n",
    "            elif op == \"trigger_pipeline\":\n",
    "                op, tgt, val = \"list_files\", \"\", \"\"\n",
    "            elif op == \"read_file\" and tgt in read_file_contents:\n",
    "                # Already read — skip to write\n",
    "                op, tgt, val = \"write_file\", tgt, read_file_contents[tgt]\n",
    "\n",
    "        # Guardrail: finalize before pipeline pass\n",
    "        if op == \"finalize\" and not pipeline_passed:\n",
    "            forced_messages.append(\"Cannot finalize until trigger_pipeline status=passed.\")\n",
    "            op, tgt, val = \"trigger_pipeline\", \"\", \"\"\n",
    "\n",
    "        action = CICDAction(op, tgt, val)\n",
    "        result = env.step(action)\n",
    "        reward = result.reward\n",
    "        obs    = result.observation\n",
    "\n",
    "        action_history.append((op, tgt, val))\n",
    "        traj.prompts.append(chat)\n",
    "        traj.responses.append(response)\n",
    "        traj.rewards.append(reward)\n",
    "        traj.steps += 1\n",
    "\n",
    "        if op == \"read_file\" and obs.get(\"last_action_success\"):\n",
    "            read_files.add(tgt)\n",
    "            content = obs.get(\"last_read_content\", \"\") or \"\"\n",
    "            if content:\n",
    "                read_file_contents[tgt] = content\n",
    "        if op == \"write_file\" and obs.get(\"last_action_success\"):\n",
    "            fix_applied_since_rerun = True\n",
    "            hypothesis_set = False  # reset so it can hypothesize again if fix fails\n",
    "            forced_messages.append(\"Fix applied. Call trigger_pipeline NOW to verify.\")\n",
    "        if op == \"trigger_pipeline\":\n",
    "            fix_applied_since_rerun = False\n",
    "            pipeline_passed = bool(obs.get(\"pipeline_passed\"))\n",
    "            if pipeline_passed:\n",
    "                forced_messages.append(\"Pipeline PASSED - call finalize NOW.\")\n",
    "            else:\n",
    "                hypothesis_set = False  # cascading fault — allow fresh hypothesis\n",
    "        if op == \"set_hypothesis\":\n",
    "            norm = _normalize_hypothesis(val)\n",
    "            if norm:\n",
    "                attempted_hypotheses.add(norm)\n",
    "            if reward > 0:\n",
    "                hypothesis_set = True\n",
    "                last_read = _last_read_path(action_history)\n",
    "                forced_messages.append(\n",
    "                    f\"Hypothesis accepted. You MUST now write_file|{last_read or '<file>'}|<complete corrected file content>. \"\n",
    "                    \"Do NOT call read_file again.\")\n",
    "            elif reward < 0:\n",
    "                hypothesis_set = False\n",
    "                forced_messages.append(\n",
    "                    \"Hypothesis incorrect. Re-read the incident alert and form a new hypothesis.\")\n",
    "\n",
    "        if verbose:\n",
    "            print(\"-\" * 70)\n",
    "            print(f\"[Step {step_i+1:2d} | OBS]\\n{obs_text[:800]}\")\n",
    "            print()\n",
    "            print(f\"[Step {step_i+1:2d} | THINK]\\n{response.strip()[:600]}\")\n",
    "            sym = \"+\" if reward > 0 else (\"-\" if reward < 0 else \"=\")\n",
    "            print(f\"[Step {step_i+1:2d} | ACT]    {op}|{tgt}|{(val or '')[:60]}\")\n",
    "            print(f\"[Step {step_i+1:2d} | REWARD] {reward:+.3f} [{sym}]  done={result.done}\")\n",
    "\n",
    "        if result.done:\n",
    "            traj.final_score = float(obs.get(\"final_score\", 0.0))\n",
    "            traj.resolved    = bool(obs.get(\"incident_resolved\", False))\n",
    "            traj.total_reward = sum(traj.rewards)\n",
    "            if verbose:\n",
    "                print(f\"\\n{'='*70}\\n[EPISODE END] score={traj.final_score:.3f} \"\n",
    "                      f\"resolved={traj.resolved} total={traj.total_reward:.3f}\\n{'='*70}\")\n",
    "            break\n",
    "\n",
    "    # Forced finalize if step budget exhausted without one\n",
    "    if (result is None or not result.done) and traj.steps > 0:\n",
    "        try:\n",
    "            r = env.step(CICDAction(\"finalize\", \"\", \"\"))\n",
    "            traj.rewards.append(r.reward)\n",
    "            traj.steps += 1\n",
    "            traj.final_score = float(r.observation.get(\"final_score\", 0.0))\n",
    "            traj.resolved    = bool(r.observation.get(\"incident_resolved\", False))\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "    traj.total_reward = sum(traj.rewards)\n",
    "    return traj\n",
    "\n",
    "print(\"Rollout function ready (parity with agent/runner.py::run_task_ws)\")"
   ]
  },
