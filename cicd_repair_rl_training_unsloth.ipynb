   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. WebSocket CI/CD Repair Env (workspace-protocol, parity with `agent/runner.py::run_task_ws`)\n",
    "\n",
    "This is the **same protocol** the inference runner uses:\n",
    "1. `POST /api/workspace/create` → temp workspace, fault injected, pre-run captures `initial_failure_logs`.\n",
    "2. Open a persistent WS at `/api/ws/{workspace_id}`.\n",
    "3. Send commands `read_file` / `write_file` / `list_files` / `trigger_pipeline`;\n",
    "   the server responds with `file_content`, `write_ack`, `file_list`, plus `stage_*` and\n",
    "   `pipeline_done` push events for pipeline runs.\n",
    "4. `set_hypothesis` and `finalize` are **local pseudo-tools** (no server round-trip),\n",
    "   exactly as in `agent/api_client.py::execute_tool`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "import asyncio, json, uuid\nimport nest_asyncio, requests, websockets\nfrom websockets.exceptions import ConnectionClosed\nfrom websockets.connection import State as _WsState\nfrom dataclasses import dataclass, field\nfrom typing import Any, Dict, List, Optional, Tuple\n\nnest_asyncio.apply()\n\n\n@dataclass\nclass CICDAction:\n    \"\"\"Action tuple matching the WS-mode action space in agent/runner.py::run_task_ws.\"\"\"\n    operation: str            # one of CICDRepairEnv.VALID_OPS\n    target:    str = \"\"       # path (read/write/list) - empty for trigger_pipeline/finalize\n    value:     str = \"\"       # file content (write_file) or hypothesis text (set_hypothesis)\n\n\n@dataclass\nclass StepResult:\n    observation: dict\n    reward: float\n    done: bool\n    info: dict = field(default_factory=dict)\n\n\nclass _PipelineResult:\n    def __init__(self):\n        self.job_id        = \"\"\n        self.status        = \"unknown\"\n        self.failed_stage  = None\n        self.duration      = None\n        self.stage_details: Dict[str, Dict[str, Any]] = {}\n\n    @property\n    def passed(self):\n        return self.status == \"passed\"\n\n\n# ── Reward table (all values in [0.0, 1.0]) ────────────────────────────────\n# Old values had negatives which hurt advantage normalisation over small batches.\n# New scale: 0.0 = wrong/failed, small positives = partial credit, 1.0 = solved.\n_R = dict(\n    read_ok        = 0.05,   # file existed and was read\n    read_fail      = 0.0,    # file missing or no path\n    read_premature = 0.0,    # read before any pipeline run (discouraged but not penalised)\n    write_ok       = 0.15,   # file written successfully\n    write_fail     = 0.0,    # write failed\n    hyp_ok         = 0.10,   # hypothesis accepted\n    hyp_fail       = 0.0,    # hypothesis rejected\n    trigger_pass   = 0.35,   # pipeline passed after fix\n    trigger_ok     = 0.05,   # pipeline ran but still failing\n    trigger_fail   = 0.0,    # trigger call itself failed\n    finalize_pass  = 1.0,    # episode solved\n    finalize_fail  = 0.0,    # finalize called but pipeline not passed\n    list_files     = 0.0,    # neutral\n    step_penalty   = 0.0,    # no per-step penalty — avoids dragging all rewards negative\n)\n\n\ndef _ws_is_open(ws) -> bool:\n    \"\"\"Compatible open-check for websockets>=12 (uses .state enum, no .open/.closed attrs).\"\"\"\n    if ws is None:\n        return False\n    try:\n        return ws.state == _WsState.OPEN\n    except AttributeError:\n        return False\n\n\nclass CICDRepairEnv:\n    \"\"\"WS env client. Mirrors agent/api_client.py + agent/ws_client.py + run_task_ws.\n\n    One workspace = one episode. reset() bootstraps a workspace via REST,\n    opens a persistent WS, and replays the pre-run logs as the incident alert.\n    step() dispatches the action and shapes the reward in [0.0, 1.0].\n    \"\"\"\n\n    VALID_OPS = [\"read_file\", \"write_file\", \"list_files\", \"trigger_pipeline\",\n                 \"set_hypothesis\", \"finalize\"]\n\n    def __init__(self, base_url: str,\n                 ws_timeout: float = 30.0,\n                 pipeline_timeout: float = 300.0):\n        self.base_url = base_url.rstrip(\"/\")\n        self.ws_url   = self.base_url.replace(\"https://\", \"wss://\").replace(\"http://\", \"ws://\")\n        self.ws_timeout       = ws_timeout\n        self.pipeline_timeout = pipeline_timeout\n\n        self._loop = None\n        self._ws   = None\n        self._recv_task = None\n        self._pending: Dict[str, asyncio.Future] = {}\n        self._pipeline_future: Optional[asyncio.Future] = None\n        self._current_pipeline: Optional[_PipelineResult] = None\n\n        # Per-episode state\n        self.workspace_id: str = \"\"\n        self.fault_injected: str = \"\"\n        self.initial_failure_logs: str = \"\"\n        self.pipeline_passed: bool = False\n        self.pipeline_triggered_once: bool = False\n        self.fix_applied_since_rerun: bool = False\n        self.read_files: set = set()\n        self.last_pipeline_logs: str = \"\"\n        self.steps_taken: int = 0\n        self.done_flag: bool = False\n\n    def _get_loop(self):\n        if self._loop is None or self._loop.is_closed():\n            try:\n                self._loop = asyncio.get_event_loop()\n            except RuntimeError:\n                self._loop = asyncio.new_event_loop()\n                asyncio.set_event_loop(self._loop)\n        return self._loop\n\n    def _create_workspace(self, fault_type: Optional[str] = None) -> Dict[str, Any]:\n        r = requests.post(f\"{self.base_url}/api/workspace/create\",\n                          json={\"fault_type\": fault_type}, timeout=120)\n        r.raise_for_status()\n        return r.json()\n\n    async def _aconnect(self):\n        await self._aclose()\n        uri = f\"{self.ws_url}/api/ws/{self.workspace_id}\"\n        self._ws = await websockets.connect(uri, ping_interval=None, open_timeout=30)\n        self._recv_task = asyncio.create_task(self._recv_loop())\n\n    async def _aclose(self):\n        if self._recv_task:\n            self._recv_task.cancel()\n            try:\n                await self._recv_task\n            except (asyncio.CancelledError, Exception):\n                pass\n            self._recv_task = None\n        if self._ws is not None:\n            try:\n                await self._ws.close()\n            except Exception:\n                pass\n            self._ws = None\n\n    def close(self):\n        loop = self._get_loop()\n        try:\n            loop.run_until_complete(self._aclose())\n        except Exception:\n            pass\n\n    async def _recv_loop(self):\n        try:\n            async for raw in self._ws:\n                try:\n                    msg = json.loads(raw)\n                except json.JSONDecodeError:\n                    continue\n                await self._dispatch(msg)\n        except ConnectionClosed:\n            pass\n        except Exception:\n            pass\n        finally:\n            for fut in list(self._pending.values()):\n                if not fut.done():\n                    fut.cancel()\n                    try:\n                        fut.exception()\n                    except Exception:\n                        pass\n            self._pending.clear()\n            if self._pipeline_future and not self._pipeline_future.done():\n                self._pipeline_future.cancel()\n                try:\n                    self._pipeline_future.exception()\n                except Exception:\n                    pass\n\n    async def _dispatch(self, msg: Dict[str, Any]):\n        rid = msg.get(\"request_id\", \"\")\n        if rid and rid in self._pending:\n            fut = self._pending.pop(rid)\n            if not fut.done():\n                if msg.get(\"type\") == \"error\":\n                    fut.set_exception(RuntimeError(msg.get(\"message\", \"unknown error\")))\n                else:\n                    fut.set_result(msg)\n            return\n\n        mt = msg.get(\"type\", \"\")\n        if mt == \"stage_completed\" and self._current_pipeline is not None:\n            stage = msg.get(\"stage\", \"\")\n            self._current_pipeline.stage_details[stage] = {\n                \"status\":   msg.get(\"status\"),\n                \"logs\":     msg.get(\"logs\", \"\") or \"\",\n                \"duration\": msg.get(\"duration\"),\n            }\n        elif mt == \"log_chunk\" and self._current_pipeline is not None:\n            stage = msg.get(\"stage\", \"\")\n            line  = str(msg.get(\"line\", \"\"))\n            d = self._current_pipeline.stage_details.setdefault(\n                stage, {\"status\": \"running\", \"logs\": \"\", \"duration\": None})\n            d[\"logs\"] = (d[\"logs\"] + (\"\\n\" if d[\"logs\"] else \"\") + line).strip()\n        elif mt == \"pipeline_done\" and self._current_pipeline is not None:\n            self._current_pipeline.status       = msg.get(\"status\", \"unknown\")\n            self._current_pipeline.failed_stage = msg.get(\"failed_stage\")\n            self._current_pipeline.duration    = msg.get(\"duration\")\n            if self._pipeline_future and not self._pipeline_future.done():\n                self._pipeline_future.set_result(self._current_pipeline)\n\n    async def _send_cmd(self, payload: Dict[str, Any]) -> Dict[str, Any]:\n        \"\"\"Send command over WS, reconnecting once if the connection is not open.\"\"\"\n        for attempt in range(2):\n            if not _ws_is_open(self._ws):\n                await self._aconnect()\n            rid = uuid.uuid4().hex[:8]\n            payload[\"request_id\"] = rid\n            fut = asyncio.get_event_loop().create_future()\n            self._pending[rid] = fut\n            try:\n                await self._ws.send(json.dumps(payload))\n                return await asyncio.wait_for(fut, timeout=self.ws_timeout)\n            except asyncio.TimeoutError:\n                self._pending.pop(rid, None)\n                raise TimeoutError(f\"WS cmd {payload['type']!r} timed out\")\n            except (ConnectionClosed, ConnectionError, OSError) as exc:\n                self._pending.pop(rid, None)\n                if attempt == 0:\n                    await self._aclose()\n                    continue\n                raise ConnectionError(f\"WS reconnect failed: {exc}\") from exc\n\n    def reset(self, fault_type: Optional[str] = None) -> dict:\n        \"\"\"Bootstrap a fresh workspace + WS session and return the initial observation dict.\"\"\"\n        loop = self._get_loop()\n        loop.run_until_complete(self._aclose())\n\n        body = self._create_workspace(fault_type=fault_type)\n        self.workspace_id        = body[\"workspace_id\"]\n        self.fault_injected      = body.get(\"fault_injected\") or \"\"\n        self.initial_failure_logs = body.get(\"initial_failure_logs\") or \"\"\n\n        self.pipeline_passed         = False\n        self.pipeline_triggered_once = bool(self.initial_failure_logs)\n        self.fix_applied_since_rerun = False\n        self.read_files              = set()\n        self.last_pipeline_logs      = self.initial_failure_logs or \"\"\n        self.steps_taken             = 0\n        self.done_flag               = False\n\n        loop.run_until_complete(self._aconnect())\n\n        return {\n            \"workspace_id\":          self.workspace_id,\n            \"fault_injected\":        self.fault_injected,\n            \"initial_failure_logs\":  self.initial_failure_logs,\n            \"pipeline_passed\":       False,\n            \"pipeline_triggered_once\": self.pipeline_triggered_once,\n            \"incident_resolved\":     False,\n            \"done\":                  False,\n        }\n\n    def step(self, action: CICDAction) -> StepResult:\n        assert action.operation in self.VALID_OPS, f\"Unknown op: {action.operation!r}\"\n        loop = self._get_loop()\n        op, tgt, val = action.operation, action.target, action.value\n\n        result_dict: Dict[str, Any] = {\"success\": False}\n        try:\n            if op == \"read_file\":\n                if not tgt:\n                    result_dict = {\"success\": False, \"error\": \"read_file requires path\"}\n                else:\n                    resp = loop.run_until_complete(self._send_cmd({\"type\": \"read_file\", \"path\": tgt}))\n                    exists = resp.get(\"exists\", False)\n                    content = resp.get(\"content\", \"\") or \"\"\n                    result_dict = {\"success\": exists, \"exists\": exists, \"path\": tgt, \"content\": content}\n\n            elif op == \"write_file\":\n                if not tgt:\n                    result_dict = {\"success\": False, \"error\": \"write_file requires path\"}\n                else:\n                    resp = loop.run_until_complete(self._send_cmd(\n                        {\"type\": \"write_file\", \"path\": tgt, \"content\": val}))\n                    ok = resp.get(\"success\", False)\n                    result_dict = {\"success\": ok, \"path\": tgt}\n\n            elif op == \"list_files\":\n                resp = loop.run_until_complete(self._send_cmd(\n                    {\"type\": \"list_files\", \"directory\": tgt}))\n                result_dict = {\"success\": True,\n                               \"files\": resp.get(\"files\", []),\n                               \"directories\": resp.get(\"directories\", [])}\n\n            elif op == \"trigger_pipeline\":\n                self._pipeline_future  = loop.create_future()\n                self._current_pipeline = _PipelineResult()\n                resp = loop.run_until_complete(self._send_cmd({\"type\": \"trigger_pipeline\"}))\n                self._current_pipeline.job_id = resp.get(\"job_id\", \"\")\n                pres = loop.run_until_complete(\n                    asyncio.wait_for(self._pipeline_future, timeout=self.pipeline_timeout))\n                self._pipeline_future = None\n                self._current_pipeline = None\n                stage_logs = []\n                for s, d in pres.stage_details.items():\n                    head = f\"--- {s}: {d.get('status')} ---\"\n                    if str(d.get('status', '')) == 'failed':\n                        body = (d.get('logs') or '')[-2000:]\n                        stage_logs.append(f\"{head}\\n{body}\")\n                    else:\n                        stage_logs.append(head)\n                self.last_pipeline_logs = \"\\n\".join(stage_logs)\n                result_dict = {\n                    \"success\": True, \"passed\": pres.passed,\n                    \"status\": pres.status, \"failed_stage\": pres.failed_stage,\n                    \"logs\": self.last_pipeline_logs,\n                }\n                self.pipeline_passed = pres.passed\n                self.pipeline_triggered_once = True\n                self.fix_applied_since_rerun = False\n\n            elif op == \"set_hypothesis\":\n                if not val:\n                    result_dict = {\"success\": False, \"error\": \"set_hypothesis requires hypothesis\"}\n                else:\n                    result_dict = {\"success\": True, \"hypothesis\": val}\n\n            elif op == \"finalize\":\n                result_dict = {\"success\": True, \"finalized\": True}\n\n        except Exception as exc:\n            result_dict = {\"success\": False, \"error\": str(exc)}\n\n        # ── Reward shaping — all values in [0.0, 1.0] ────────────────────────\n        op_success = result_dict.get(\"success\", False)\n\n        if op == \"trigger_pipeline\":\n            if result_dict.get(\"passed\"):\n                reward = _R[\"trigger_pass\"]\n            elif op_success:\n                reward = _R[\"trigger_ok\"]\n            else:\n                reward = _R[\"trigger_fail\"]\n        elif op == \"set_hypothesis\":\n            reward = _R[\"hyp_ok\"] if op_success else _R[\"hyp_fail\"]\n        elif op == \"write_file\":\n            reward = _R[\"write_ok\"] if op_success else _R[\"write_fail\"]\n            if op_success:\n                self.fix_applied_since_rerun = True\n        elif op == \"read_file\":\n            if op_success and result_dict.get(\"exists\"):\n                reward = _R[\"read_ok\"] if self.pipeline_triggered_once else _R[\"read_premature\"]\n                self.read_files.add(tgt)\n            else:\n                reward = _R[\"read_fail\"]\n        elif op == \"list_files\":\n            reward = _R[\"list_files\"]\n        elif op == \"finalize\":\n            reward = _R[\"finalize_pass\"] if self.pipeline_passed else _R[\"finalize_fail\"]\n            self.done_flag = True\n        else:\n            reward = 0.0\n\n        self.steps_taken += 1\n        done = self.done_flag\n\n        obs = {\n            \"workspace_id\":            self.workspace_id,\n            \"fault_injected\":          self.fault_injected,\n            \"step\":                    self.steps_taken,\n            \"last_action\":             [op, tgt, (val[:120] if val else \"\")],\n            \"last_action_success\":     op_success,\n            \"last_action_error\":       result_dict.get(\"error\", \"\"),\n            \"pipeline_passed\":         self.pipeline_passed,\n            \"pipeline_triggered_once\": self.pipeline_triggered_once,\n            \"fix_applied_since_rerun\": self.fix_applied_since_rerun,\n            \"incident_resolved\":       self.pipeline_passed,\n            \"last_pipeline_logs\":      self.last_pipeline_logs,\n            \"last_read_path\":          tgt if op == \"read_file\" and op_success else \"\",\n            \"last_read_content\":       result_dict.get(\"content\", \"\") if op == \"read_file\" else \"\",\n            \"files\":                   result_dict.get(\"files\", []) if op == \"list_files\" else [],\n            \"directories\":             result_dict.get(\"directories\", []) if op == \"list_files\" else [],\n            \"done\":                    done,\n            \"reward\":                  reward,\n            \"final_score\":             1.0 if (op == \"finalize\" and self.pipeline_passed) else 0.0,\n            \"task_id\":                 self.fault_injected or \"unknown\",\n            \"difficulty\":              \"\",\n        }\n        return StepResult(observation=obs, reward=reward, done=done, info={})\n\n    def obs_to_text(self, obs: dict, step_num: int = 0) -> str:\n        parts: List[str] = []\n        parts.append(f\"workspace={obs.get('workspace_id','')[:8]}  fault={obs.get('fault_injected','?')}\")\n        parts.append(f\"Step {step_num}  pipeline_passed={obs.get('pipeline_passed', False)}  \"\n                     f\"triggered_once={obs.get('pipeline_triggered_once', False)}\")\n\n        if step_num == 0 or not obs.get(\"last_action\"):\n            logs = self.initial_failure_logs or \"\"\n            if logs:\n                parts.append(\"=== INCIDENT ALERT - pre-run pipeline output ===\")\n                parts.append(logs[-3000:] + (\"\" if len(logs) <= 3000 else \"\"))\n                parts.append(\"=== END INCIDENT ALERT ===\")\n        else:\n            la = obs.get(\"last_action\") or [\"?\", \"\", \"\"]\n            ok = obs.get(\"last_action_success\")\n            err = obs.get(\"last_action_error\") or \"\"\n            parts.append(f\"Last action: {la[0]}|{la[1]}|{(la[2] or '')[:60]}  ok={ok}  \"\n                         + (f\"err={err[:120]}\" if err else \"\"))\n            if la[0] == \"read_file\" and obs.get(\"last_read_content\"):\n                content = obs[\"last_read_content\"]\n                parts.append(f\"--- {la[1]} ({len(content.splitlines())} lines) ---\")\n                parts.append(\"\\n\".join(content.splitlines()[:80]))\n                if content.count(\"\\n\") > 80:\n                    parts.append(\"...\")\n            elif la[0] == \"trigger_pipeline\":\n                logs = obs.get(\"last_pipeline_logs\") or \"\"\n                parts.append(logs[-3000:] + (\"\" if len(logs) <= 3000 else \"\"))\n            elif la[0] == \"list_files\":\n                if obs.get(\"directories\"):\n                    parts.append(\"dirs: \" + \", \".join(obs[\"directories\"][:30]))\n                if obs.get(\"files\"):\n                    parts.append(\"files: \" + \", \".join(obs[\"files\"][:30]))\n\n        if obs.get(\"incident_resolved\"):\n            parts.append(\"*** PIPELINE PASSED - call finalize NOW ***\")\n        return \"\\n\".join(parts)\n\n\n# Smoke test\nprint(\"Probing /health & /api/workspace/create...\")\ntry:\n    r = requests.get(f\"{ENV_BASE_URL}/health\", timeout=10)\n    print(f\"  /health -> {r.json()}\")\nexcept Exception as e:\n    print(f\"  /health failed: {e}\")\n\nimport builtins as _builtins\n_prev = getattr(_builtins, \"_cicd_env\", None)\nif _prev is not None:\n    print(\"Closing previous env WS session...\")\n    _prev.close()\n\nenv = CICDRepairEnv(ENV_BASE_URL)\n_builtins._cicd_env = env\nobs = env.reset()\nprint(f\"CICDRepairEnv (workspace+WS) OK  --  workspace={env.workspace_id[:8]}  \"\n      f\"fault={env.fault_injected}\")\nprint()\nprint(env.obs_to_text(obs, 0)[:800])\nprint()\nprint(\"Reward table (all values in [0.0, 1.0]):\", _R)\n"
  },
