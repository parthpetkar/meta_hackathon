    "iters = hist['iteration']\n",
    "\n",
    "axes[0,0].plot(iters, hist['avg_reward'], 'b-o', ms=4)\n",
    "axes[0,0].set_title('Avg Episode Reward')\n",
    "axes[0,0].axhline(0, color='gray', ls='--', alpha=0.5)\n",
    "\n",
    "axes[0,1].plot(iters, hist['avg_score'], 'g-o', ms=4)\n",
    "axes[0,1].set_title('Avg Final Score [0-1]')\n",
    "axes[0,1].set_ylim(0, 1)\n",
    "\n",
    "axes[1,0].plot(iters, [r*100 for r in hist['resolved_rate']], 'r-o', ms=4)\n",
    "axes[1,0].set_title('Resolution Rate (%)')\n",
    "axes[1,0].set_ylim(0, 105)\n",
    "\n",
    "axes[1,1].plot(iters, hist['loss'], color='purple', marker='o', ms=4)\n",
    "axes[1,1].set_title('GRPO Loss')\n",
    "\n",
    "for ax in axes.flat:\n",
    "    ax.set_xlabel('Iteration'); ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('/content/training_metrics.png', dpi=150, bbox_inches='tight')\n",
