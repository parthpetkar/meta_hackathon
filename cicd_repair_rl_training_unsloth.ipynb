    "from torch.optim import AdamW\n",
    "from torch.nn.utils import clip_grad_norm_\n",
    "import gc, os\n",
    "\n",
    "GRPO_CFG = dict(\n",
    "    num_iterations    = 20,\n",
    "    episodes_per_iter = 3,    # back to 3 — needed for stable advantage normalisation\n",
    "    learning_rate     = 2e-5, # was 5e-5 — lower LR to stop the 0% collapse at iter 10-11\n",
    "    max_steps_per_ep  = 8,\n",
    "    gamma             = 0.99,\n",
    "    kl_coef           = 0.02,\n",
    "    grad_clip         = 0.5,  # was 1.0 — tighter clipping helps stability\n",
    "    save_every        = 5,\n",
    "    checkpoint_dir    = '/data/checkpoints',\n",
    ")\n",
    "os.makedirs(GRPO_CFG['checkpoint_dir'], exist_ok=True)\n",
    "\n",
    "\n",
    "def compute_returns(rewards, gamma=0.99):\n",
    "    returns, R = [], 0.0\n",
    "    for r in reversed(rewards):\n",
    "        R = r + gamma * R\n",
    "        returns.insert(0, R)\n",
    "    return returns\n",
    "\n",
    "\n",
    "def grpo_loss(model, tokenizer, trajectories, kl_coef=0.02):\n",
    "    all_r = [r for t in trajectories for r in t.rewards]\n",
    "    if not all_r:\n",
    "        return torch.tensor(0.0, requires_grad=True)\n",
    "    mean_r = sum(all_r) / len(all_r)\n",
    "    std_r  = (sum((r - mean_r)**2 for r in all_r) / len(all_r))**0.5 + 1e-8\n",
    "\n",
    "    loss_terms = []\n",
    "    total_toks  = 0\n",
    "\n",
    "    for traj in trajectories:\n",
    "        returns = compute_returns(traj.rewards, gamma=GRPO_CFG['gamma'])\n",
    "        for prompt, response, ret in zip(traj.prompts, traj.responses, returns):\n",
    "            advantage = (ret - mean_r) / std_r\n",
    "\n",
    "            # Skip near-zero advantage steps — they add noise but no signal\n",
    "            if abs(advantage) < 0.05:\n",
    "                continue\n",
    "\n",
    "            enc = tokenizer(\n",
    "                prompt + response, return_tensors='pt',\n",
    "                truncation=True, max_length=MAX_SEQ_LEN).to(model.device)\n",
    "            plen = tokenizer(\n",
    "                prompt, return_tensors='pt',\n",
    "                truncation=True, max_length=MAX_SEQ_LEN).input_ids.shape[1]\n",
    "            labels = enc.input_ids.clone()\n",
    "            labels[0, :plen] = -100\n",
    "            out    = model(**enc, labels=labels)\n",
    "            n_toks = max(1, enc.input_ids.shape[1] - plen)\n",
    "            loss_terms.append(advantage * out.loss * n_toks)\n",
    "            total_toks += n_toks\n",
    "\n",
    "    if not loss_terms:\n",
    "        return torch.tensor(0.0, requires_grad=True)\n",
    "\n",
    "    return -torch.stack(loss_terms).sum() / max(1, total_toks)\n",
    "\n",
    "\n",
    "print('GRPO configured')\n",
    "print(f'  Iterations    : {GRPO_CFG[\"num_iterations\"]}')\n",
    "print(f'  Episodes/iter : {GRPO_CFG[\"episodes_per_iter\"]}')\n",
    "print(f'  LR            : {GRPO_CFG[\"learning_rate\"]}')\n",
    "print(f'  Grad clip     : {GRPO_CFG[\"grad_clip\"]}')"
   ]
