    "import os, gc, torch\n",
    "\n",
    "PLOTS_DIR = 'plots'\n",
    "os.makedirs(PLOTS_DIR, exist_ok=True)\n",
    "\n",
    "BASELINE_EPISODES = 6   # must match NUM_EVAL below so bars are comparable\n",
