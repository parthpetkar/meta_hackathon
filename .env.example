# Provider mode for inference/rubric client creation:
# - hf         -> hackathon-compatible Hugging Face router
# - openrouter -> testing
# - groq       -> testing
LLM_PROVIDER=hf

# OpenAI-compatible endpoint + model
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Provider keys (set the one matching your provider)
HF_TOKEN=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Optional explicit override (normally leave empty)
# API_KEY=

# OpenRouter attribution headers (used when provider is openrouter)
OPENROUTER_REFERER=https://your-site.com
OPENROUTER_TITLE=meta_hackathon

# Local Docker image used by MetaHackathonEnv.from_docker_image().
LOCAL_IMAGE_NAME=meta_hackathon-env:latest

# Optional fallback if your setup still uses IMAGE_NAME.
IMAGE_NAME=meta_hackathon-env:latest

# Use server mode if you are testing a running local server instead of Docker.
ENV_BASE_URL=http://localhost:8000

# Benchmark name used in [START] logs.
META_HACKATHON_BENCHMARK=meta_hackathon

# Episode count: each reset() gets a new challenge from the LLM adversarial designer.
# Fault selection is ALWAYS by LLM (not curriculum).
# Difficulty is scheduled by server-side curriculum (UCB1 + EMA).
# Default: 6 episodes per inference run.
META_HACKATHON_NUM_EPISODES=6

# Scenario construction style (controls HOW faults are injected, not WHAT fault):
# - procedural/combo -> use deterministic multi-fault generator (input: LLM-chosen root cause)
# - anything else    -> use LLM-generated multi-fault scenario (default)
# Fault/scenario is ALWAYS decided by LLM adversarial designer.
META_HACKATHON_TASK_MODE=cycle

# Agent/runtime controls
HTTP_TIMEOUT_SECONDS=180
META_HACKATHON_PIPELINE_TIMEOUT_SECONDS=300
MAX_MODEL_CALLS_PER_TASK=64
MAX_CONSECUTIVE_TOOL_CALL_MISSES=4
MIN_MODEL_CALLS_BEFORE_STRICT_FAIL=4

# Optional local-only verbose inference logs.
# Keeps strict START/STEP/END lines and appends extra [DETAIL] lines when enabled.
INFERENCE_VERBOSE=true
INFERENCE_DETAIL_MAX_ITEMS=3
SUCCESS_SCORE_THRESHOLD=0.20

# Optional provenance audit trail in reset/step metadata.
# When true, observations include deterministic sampled pattern lineage fields.
META_HACKATHON_AUDIT_TRAIL=true

# Rubric delayed-reward controls
META_HACKATHON_RUBRIC_ENABLED=true
META_HACKATHON_RUBRIC_WEIGHT=0.20
META_HACKATHON_RUBRIC_TIMEOUT_SECONDS=10
META_HACKATHON_RUBRIC_MODEL=Qwen/Qwen2.5-72B-Instruct
META_HACKATHON_RUBRIC_DEBUG=false

# Optional override for rubric provider specifically (defaults to LLM_PROVIDER)
RUBRIC_LLM_PROVIDER=openrouter

# Mid-episode state/schema drift injection (experimental world-modeling feature).
# Drift fires only after the pipeline passes, introducing a new failure that forces
# re-investigation. This tests persistent world modeling instead of static fix memorization.
META_HACKATHON_DRIFT_ENABLED=false
META_HACKATHON_DRIFT_PROBABILITY=0.4

# =============================================================================
# Database service layer (db/database.py + docker-compose.yml)
# =============================================================================

# Which database backend to use.
#   sqlite   — default; no extra services, zero startup cost.
#   postgres — activate with: docker compose --profile postgres up
DB_BACKEND=sqlite

# Full connection URL (leave unset; computed from DB_BACKEND when blank).
#   SQLite default:   sqlite:///./app.db
#   Postgres default: postgresql://app:secret@db:5432/appdb
# DATABASE_URL=

# ---------------------------------------------------------------------------
# Database fault-injection flags (curriculum scenarios)
# Set one to "true" before `docker compose up` to inject the fault.
# The repair agent must detect and fix the failure. See db/faults.py.
# ---------------------------------------------------------------------------

# Syntax error in 001_init.sql: "CREAT TABLE" instead of "CREATE TABLE".
# Fix: restore "CREATE TABLE" in db/migrations/001_init.sql.
BAD_MIGRATION_SQL=false

# ORM model references column "artifact_url" that was never migrated into builds.
# Fix: add a migration that adds artifact_url, or remove it from CANONICAL_COLUMNS.
SCHEMA_DRIFT=false

# pgdata volume mount commented out in docker-compose.yml (postgres profile only).
# Fix: restore "- pgdata:/var/lib/postgresql/data" under db.volumes.
MISSING_VOLUME=false

# Double-slash typo in Postgres host: "postgresql://app:secret@//db:5432/appdb".
# Fix: remove the extra slash in DATABASE_URL.
WRONG_DATABASE_URL=false

# depends_on db healthcheck guard removed from env-server (postgres profile only).
# Fix: re-add "depends_on: db: condition: service_healthy" to env-server.
INIT_ORDER_RACE=false
