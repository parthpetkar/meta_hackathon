# API endpoint for the OpenAI-compatible router.
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier used by the inference script.
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Hugging Face token or API key.
HF_TOKEN=

# Local Docker image used by MetaHackathonEnv.from_docker_image().
LOCAL_IMAGE_NAME=meta_hackathon-env:latest

# Optional fallback if your setup still uses IMAGE_NAME.
IMAGE_NAME=meta_hackathon-env:latest

# Optional task metadata used in the stdout header.
MY_ENV_V4_TASK=echo
MY_ENV_V4_BENCHMARK=my_env_v4